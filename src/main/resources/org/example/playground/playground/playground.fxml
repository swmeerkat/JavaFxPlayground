<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import java.net.URL?>
<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="org.example.playground.playground.PlaygroundController">
    <stylesheets>
        <URL value="@playground.css"/>
    </stylesheets>
    <Canvas fx:id="canvas" width="1200" height="900"/>

    <Label fx:id="startText" textFill="white"/>
    <Button text="Start" onAction="#onStartClick"/>
</VBox>